<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Logged Out — Food Bank Tracker</title>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family:
        -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background-color: #f0f2f5;
      color: #1a1a2e;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /*  Navbar */
    nav {
      background-color: #1a2c4e;
      padding: 0 2rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-brand {
      color: #ffffff;
      font-size: 1.1rem;
      font-weight: 700;
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 1.5rem;
      list-style: none;
    }

    .nav-links a {
      color: #cbd5e1;
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: #ffffff;
    }

    /* ── Main content ── */
    main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .card {
      background: #ffffff;
      border-radius: 8px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 420px;
      text-align: center;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
    }

    .icon-wrap {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background-color: #e8f5e9;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.25rem;
    }

    .icon-wrap svg {
      width: 32px;
      height: 32px;
      stroke: #2e7d32;
      fill: none;
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .card h1 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #1a1a2e;
    }

    .card p {
      color: #64748b;
      font-size: 0.95rem;
      margin-bottom: 1.75rem;
      line-height: 1.5;
    }

    .divider {
      border: none;
      border-top: 1px solid #e2e8f0;
      margin-bottom: 1.75rem;
    }

    /* Buttons */
    .btn-primary {
      display: block;
      width: 100%;
      padding: 0.75rem;
      background-color: #1a2c4e;
      color: #ffffff;
      border: none;
      border-radius: 6px;
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition: background-color 0.2s;
      margin-bottom: 0.75rem;
    }

    .btn-primary:hover {
      background-color: #243d6b;
    }

    .btn-secondary {
      display: block;
      width: 100%;
      padding: 0.75rem;
      background-color: #ffffff;
      color: #1a2c4e;
      border: 1.5px solid #1a2c4e;
      border-radius: 6px;
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition:
        background-color 0.2s,
        color 0.2s;
    }

    .btn-secondary:hover {
      background-color: #1a2c4e;
      color: #ffffff;
    }

    /* ── Footer ── */
    footer {
      background-color: #ffffff;
      border-top: 1px solid #e2e8f0;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.8rem;
      color: #64748b;
    }

    footer a {
      color: #64748b;
      text-decoration: none;
      margin-left: 1rem;
    }

    footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body>
  <!-- Navbar -->
  <nav>
    <a href="/" class="nav-brand">Food Bank Tracker</a>
    <ul class="nav-links">
      <li><a href="/request">Requests</a></li>
      <li><a href="/login">Login</a></li>
    </ul>
  </nav>

  <!-- Card -->
  <main>
    <div class="card">
      <!-- Green checkmark -->
      <div class="icon-wrap">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </div>

      <h1>You've been logged out</h1>
      <p>
        You've successfully signed out of your account.<br />See you next
        time!
      </p>

      <hr class="divider" />

      <a href="/login" class="btn-primary">Log back in</a>
      <a href="/" class="btn-secondary">Go to homepage</a>
    </div>
  </main>

  <!-- Footer -->
  <footer>
    <span>© 2026 Food Bank Tracker</span>
    <div>
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
      <a href="/contact">Contact Support</a>
    </div>
  </footer>

</body>

</html>