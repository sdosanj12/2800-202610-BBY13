<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>History &amp; Audit Log — Food Bank Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/audit-log-admin.css" />
</head>
<body>

  <!-- TOPBAR -->
  <nav class="topbar">
    <a href="/admin/dashboard" class="topbar-brand">🥫 Food Bank Tracker</a>
    <div class="topbar-right">
      <span class="topbar-user">Admin: <strong><%= username %></strong></span>
      <a href="/admin/logout" class="btn-shell btn-shell-outline">Log out</a>
    </div>
  </nav>

  <div class="shell">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-label">Overview</div>
        <a href="/admin/dashboard" class="sidebar-link"><span class="icon">📊</span> Dashboard</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Inventory</div>
        <a href="/admin/inventory" class="sidebar-link"><span class="icon">📦</span> All Items</a>
        <a href="/admin/audit-log" class="sidebar-link active"><span class="icon">📋</span> History &amp; Audit Log</a>
        <a href="/admin/low-stock-alerts" class="sidebar-link"><span class="icon">⚠️</span> Low Stock Alerts</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Employees</div>
        <a href="/admin/employees" class="sidebar-link"><span class="icon">👥</span> All Employees</a>
        <a href="/admin/employees/codes" class="sidebar-link"><span class="icon">🔑</span> Generate Codes</a>
      </div>
      <div class="sidebar-bottom">
        <strong><%= username %></strong>
        <a href="/admin/logout">Log out</a>
      </div>
    </aside>

    <!-- CONTENT -->
    <main class="content">
      <div class="page-header">
        <h1>History &amp; Audit Log</h1>
        <div class="sub"><%= new Date().toLocaleDateString('en-CA', {weekday:'long',year:'numeric',month:'long',day:'numeric'}) %></div>
      </div>

      <!-- Stat Cards -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Total Events</div>
          <div class="stat-value"><%= stats.total.toLocaleString() %></div>
          <div class="stat-sub">All time</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Today</div>
          <div class="stat-value"><%= stats.today %></div>
          <div class="stat-sub">Events logged today</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Items Added</div>
          <div class="stat-value"><%= stats.added %></div>
          <div class="stat-sub">This month</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Requests</div>
          <div class="stat-value"><%= stats.requests %></div>
          <div class="stat-sub">Approved this month</div>
        </div>
      </div>

      <!-- Log Panel -->
      <div class="panel">
        <div class="panel-header"><h2>Audit Log</h2></div>

        <!-- Filter Bar -->
        <form method="GET" action="/admin/audit-log">
          <div class="filter-bar">
            <input class="filter-input" type="text" name="search" placeholder="Search by item or user…" value="<%= filters.search || '' %>" />
            <select class="filter-select" name="action">
              <option value="">All Actions</option>
              <% ['added','updated','deleted','approved','denied','pickup'].forEach(a => { %>
                <option value="<%= a %>" <%= filters.action === a ? 'selected' : '' %>><%= a.charAt(0).toUpperCase()+a.slice(1) %></option>
              <% }) %>
            </select>
            <input class="filter-date" type="date" name="dateFrom" value="<%= filters.dateFrom || '' %>" />
            <input class="filter-date" type="date" name="dateTo" value="<%= filters.dateTo || '' %>" />
            <button type="submit" class="btn-filter">Filter</button>
            <a href="/admin/audit-log" class="btn-clear">Clear</a>
          </div>
        </form>

        <!-- Table -->
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Timestamp</th>
                <th>Action</th>
                <th>Item / Subject</th>
                <th>Details</th>
                <th>Performed By</th>
                <th>Role</th>
              </tr>
            </thead>
            <tbody>
              <% if (events.length === 0) { %>
                <tr><td colspan="6" class="empty-state">No log entries match your filters.</td></tr>
              <% } else { %>
                <% events.forEach(e => {
                  const chipClass = {added:'chip-added',updated:'chip-updated',deleted:'chip-deleted',approved:'chip-approved',denied:'chip-denied',pickup:'chip-pickup'}[e.action] || '';
                  const dotClass  = {added:'dot-added',updated:'dot-updated',deleted:'dot-deleted',approved:'dot-approved',denied:'dot-denied',pickup:'dot-pickup'}[e.action] || '';
                %>
                  <tr>
                    <td class="ts"><%= new Date(e.ts).toLocaleString('en-CA',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></td>
                    <td><span class="chip <%= chipClass %>"><%= e.action.charAt(0).toUpperCase()+e.action.slice(1) %></span></td>
                    <td style="font-weight:600;"><%= e.item %></td>
                    <td class="details"><%= e.details %></td>
                    <td>
                      <div class="user-cell">
                        <span class="dot <%= dotClass %>"></span>
                        <%= e.user %>
                      </div>
                    </td>
                    <td style="color:var(--color-muted);"><%= e.role %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Footer / Pagination -->
        <div class="panel-footer">
          <small>Showing <%= events.length %> of <%= stats.total %> events</small>
          <% if (totalPages > 1) { %>
            <ul class="pagination">
              <li class="<%= page <= 1 ? 'disabled' : '' %>">
                <a href="/admin/audit-log?page=<%= page-1 %>&<%= queryString %>">‹</a>
              </li>
              <% for (let i = Math.max(1, page-2); i <= Math.min(totalPages, page+2); i++) { %>
                <li class="<%= i === page ? 'active' : '' %>">
                  <a href="/admin/audit-log?page=<%= i %>&<%= queryString %>"><%= i %></a>
                </li>
              <% } %>
              <li class="<%= page >= totalPages ? 'disabled' : '' %>">
                <a href="/admin/audit-log?page=<%= page+1 %>&<%= queryString %>">›</a>
              </li>
            </ul>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <footer class="site-footer">
    <span>© 2026 Food Bank Tracker</span>
    <div class="footer-links">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
      <a href="#">Contact Support</a>
    </div>
  </footer>

</body>
</html>