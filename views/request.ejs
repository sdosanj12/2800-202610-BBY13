<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Request Food | Food Bank Tracker</title>
    <!-- Using absolute path /style.css so deep nested routing works flawlessly -->
    <link rel="stylesheet" href="/style.css">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Alan+Sans:wght@300..900&family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Lexend+Deca:wght@100..900&display=swap"
        rel="stylesheet">

    <!-- Including Bootstrap for clean form controls layout alignment -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Native EJS Server-side layout partial -->
    <header id="navbar-container">
        <%- include('partials/navbar') %>
    </header>

    <main class="container my-5">
        <section class="card shadow-sm p-4 max-width-form mx-auto">
            <h1 class="mb-2">Food Request Form</h1>
            <p class="text-muted mb-4">Please fill out the details below to help us prepare your package accurately.</p>

            <form id="food-request-form" action="/requests/submit" method="POST">

                <!-- Household Size -->
                <div class="mb-4">
                    <label for="household-size" class="form-label fw-semibold">Household Size</label>
                    <select id="household-size" name="householdSize" class="form-select" required>
                        <option value="">Select size...</option>
                        <option value="small">Small (1-2 people)</option>
                        <option value="medium">Medium (3-4 people)</option>
                        <option value="large">Large (5+ people)</option>
                    </select>
                    <div class="form-text">
                        Need allocation details? <a href="/guidelines/sizes" target="_blank">View quantities per
                            household size</a>.
                    </div>
                </div>

                <!-- Dietary Restrictions -->
                <div class="mb-4">
                    <label class="form-label fw-semibold d-block">Dietary Needs / Restrictions</label>
                    <div class="checkbox-group p-3 bg-white border rounded">
                        <div class="form-check mb-2">
                            <input type="checkbox" id="halal" name="diet" value="halal" class="form-check-input">
                            <label for="halal" class="form-check-label">Halal</label>
                        </div>
                        <div class="form-check mb-2">
                            <input type="checkbox" id="vegan" name="diet" value="vegan" class="form-check-input">
                            <label for="vegan" class="form-check-label">Vegan / Vegetarian</label>
                        </div>
                        <div class="form-check mb-2">
                            <input type="checkbox" id="gluten-free" name="diet" value="gluten-free"
                                class="form-check-input">
                            <label for="gluten-free" class="form-check-label">Gluten-Free</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" id="dairy-free" name="diet" value="dairy-free"
                                class="form-check-input">
                            <label for="dairy-free" class="form-check-label">Dairy-Free</label>
                        </div>
                    </div>
                    <div class="form-text">
                        <a href="/guidelines/dietary" target="_blank">View our dietary validation policy</a>
                    </div>
                </div>

                <!-- Pickup Location -->
                <div class="mb-4">
                    <label for="location" class="form-label fw-semibold">Pickup Location (Vancouver, BC)</label>
                    <select id="location" name="location" class="form-select" required>
                        <option value="">Select a location...</option>
                        <option value="east-van">East Vancouver Hub</option>
                        <option value="kitsilano">Kitsilano Community Center</option>
                        <option value="downtown">Downtown Eastside Annex</option>
                    </select>
                    <div class="form-text">
                        <a href="/locations/info" target="_blank">View addresses and operation hours</a>
                    </div>
                </div>

                <!-- Date and Time Inputs side-by-side using Bootstrap grid -->
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="pickup-date" class="form-label fw-semibold">Preferred Pickup Date</label>
                        <input type="date" id="pickup-date" name="pickupDate" class="form-select" required>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label for="pickup-time" class="form-label fw-semibold">Preferred Time Slot</label>
                        <input type="time" id="pickup-time" name="pickupTime" class="form-select" required>
                    </div>
                </div>
                <div class="form-text mb-4 mt-n2">
                    <a href="/locations/availability" target="_blank">🔎 Check dynamic real-time traffic calendar
                        slots</a>
                </div>

                <hr class="my-4">

                <!-- Actions System -->
                <div class="d-flex gap-3 justify-content-end">
                    <button type="reset" class="btn btn-outline-secondary rounded-pill px-4">Clear Form</button>
                    <button type="submit" class="btn btn-dark rounded-pill px-4">Submit Request</button>
                </div>

            </form>
        </section>
    </main>

    <footer class="footer mt-auto">
        <%- include('partials/footer') %>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>