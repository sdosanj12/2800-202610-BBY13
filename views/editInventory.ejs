<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Edit Inventory Item</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4">

    <h1>Edit <%= item.name %>
    </h1>

    <form action="/inventory/<%= item._id %>?_method=PATCH" method="POST" class="mt-3">

        <div class="mb-3">
            <label class="form-label">Quantity</label>
            <input type="number" name="quantity" class="form-control" value="<%= item.quantity %>" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Storage Location</label>
            <select name="storageLocation" class="form-select" required>
                <option value="shelf" <%=item.storageLocation==="shelf" ? "selected" : "" %>>Shelf</option>
                <option value="fridge" <%=item.storageLocation==="fridge" ? "selected" : "" %>>Fridge</option>
                <option value="freezer" <%=item.storageLocation==="freezer" ? "selected" : "" %>>Freezer</option>
                <option value="pantry" <%=item.storageLocation==="pantry" ? "selected" : "" %>>Pantry</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Expiry Date</label>
            <input type="date" name="expiryDate" class="form-control"
                value="<%= item.expiryDate ? item.expiryDate.toISOString().slice(0,10) : '' %>">
        </div>

        <button type="submit" class="btn btn-success">Save Changes</button>
        <a href="/inventory" class="btn btn-secondary">Cancel</a>
    </form>

</body>

</html>