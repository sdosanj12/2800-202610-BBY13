<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Request Successful | Food Bank Tracker</title>
    <link rel="stylesheet" href="style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Alan+Sans:wght@300..900&family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Lexend+Deca:wght@100..900&display=swap" rel="stylesheet">
</head>

<body>

    <header>
        <%- include('partials/navbar') %>
    </header>

    <main class="container">
        <section class="card" style="text-align: center; padding: 3rem 2rem;">
            <h1>Request Submitted!</h1>
            <p>Thank you for reaching out. Your food request has been received by our Vancouver team.</p>
            
            <div class="status-badge">Reference: #<%= referenceId %></div>

            <div class="next-steps">
                <h3>What happens next?</h3>
                <p>
                    <strong>Preparation:</strong> Our volunteers will check our current inventory against your dietary needs.<br>
                    <strong>Confirmation:</strong> You will receive a confirmation email/SMS once your hamper is packed.<br>
                    <strong>Pickup:</strong> Please arrive at your chosen location during your selected time slot.<br>
                </p>
            </div>

            <div style="margin-top: 2.5rem;">
                <button type="button" class="btn-primary" onclick="location.href='/'">
                    Return to Home
                </button>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

</body>

</html>