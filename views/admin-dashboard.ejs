<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard — Food Bank Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue-dark:  #1a4f7a;
      --blue-mid:   #1e5f94;
      --bg:         #f5f6f8;
      --white:      #ffffff;
      --text-dark:  #2c3e50;
      --text-muted: #6c7a89;
      --border:     #dce3ea;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text-dark);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── TOPBAR ── */
    .topbar {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      flex-shrink: 0;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .topbar-left h1 {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text-dark);
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .btn {
      padding: 0.5rem 1.1rem;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      border: 1.5px solid var(--border);
      background: var(--white);
      color: var(--text-dark);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }

    .btn:hover { background: var(--bg); }

    .btn-primary {
      background: var(--blue-dark);
      color: var(--white);
      border-color: var(--blue-dark);
    }

    .btn-primary:hover { background: var(--blue-mid); border-color: var(--blue-mid); }

    /* ── LAYOUT ── */
    .layout {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      width: 220px;
      background: var(--white);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      padding: 1.25rem 0;
    }

    .sidebar-section {
      margin-bottom: 1.5rem;
    }

    .sidebar-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 0 1.25rem;
      margin-bottom: 0.4rem;
    }

    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.55rem 1.25rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-dark);
      text-decoration: none;
      border-left: 3px solid transparent;
      transition: background 0.15s, border-color 0.15s;
    }

    .sidebar-link:hover {
      background: var(--bg);
    }

    .sidebar-link.active {
      background: #edf3f9;
      border-left-color: var(--blue-dark);
      color: var(--blue-dark);
      font-weight: 600;
    }

    .sidebar-link .icon {
      width: 16px;
      text-align: center;
      font-size: 0.9rem;
      opacity: 0.7;
    }

    .sidebar-bottom {
      margin-top: auto;
      padding: 1rem 1.25rem;
      border-top: 1px solid var(--border);
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .sidebar-bottom strong {
      display: block;
      color: var(--text-dark);
      font-size: 0.85rem;
      margin-bottom: 2px;
    }

    .sidebar-bottom a {
      color: var(--blue-dark);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.8rem;
    }

    /* ── MAIN CONTENT ── */
    .content {
      flex: 1;
      overflow-y: auto;
      padding: 1.75rem;
    }

    /* ── STAT CARDS ── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .stat-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
    }

    .stat-card .stat-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.5rem;
    }

    .stat-card .stat-value {
      font-size: 2rem;
      font-weight: 700;
      color: var(--blue-dark);
      line-height: 1;
    }

    .stat-card .stat-sub {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-top: 0.3rem;
    }

    /* ── PANELS ROW ── */
    .panels-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .panel {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
    }

    .panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--border);
    }

    .panel-header h2 {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text-dark);
    }

    .panel-body {
      padding: 1.25rem;
      min-height: 240px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      font-size: 0.875rem;
    }
  </style>
</head>
<body>

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-left">
      <h1>Admin Dashboard — <%= employee.name %></h1>
    </div>
    <div class="topbar-right">
      <a href="/admin/export" class="btn">Export Report</a>
      <a href="/admin/employees/codes" class="btn btn-primary">+ Add Employee</a>
    </div>
  </div>

  <div class="layout">

    <!-- SIDEBAR -->
  <aside class="sidebar">
    <!-- [ADDED] New "Overview" section with Dashboard as the active link -->
    <div class="sidebar-section">
      <div class="sidebar-label">Overview</div>
      <a href="/admin/dashboard" class="sidebar-link active">
        <span class="icon">📊</span> Dashboard
      </a>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">Inventory</div>
      <a href="/admin/inventory" class="sidebar-link">
        <span class="icon">📦</span> All Items
      </a>
      <a href="/admin/inventory/history" class="sidebar-link">
        <span class="icon">📋</span> History &amp; Audit Log
      </a>
      <a href="/admin/inventory/alerts" class="sidebar-link">
        <span class="icon">⚠️</span> Low Stock Alerts
      </a>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">Employees</div>
      <!-- [CHANGED] Removed class "active" from this link — it was incorrectly highlighted -->
      <a href="/admin/employees" class="sidebar-link">
        <span class="icon">👥</span> All Employees
      </a>
      <a href="/admin/employees/codes" class="sidebar-link">
        <span class="icon">🔑</span> Generate Codes
      </a>
    </div>

    <div class="sidebar-bottom">
      <strong><%= employee.name %></strong>
      <%= employee.employeeId %><br />
      <a href="/admin/logout">Log out</a>
    </div>
  </aside>

    <!-- MAIN CONTENT -->
    <main class="content">

      <!-- Stat cards -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Inventory Items</div>
          <div class="stat-value">—</div>
          <div class="stat-sub">Total in stock</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Pending Requests</div>
          <div class="stat-value">—</div>
          <div class="stat-sub">Awaiting review</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Active Volunteers</div>
          <div class="stat-value">—</div>
          <div class="stat-sub">This week</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Registered Clients</div>
          <div class="stat-value">—</div>
          <div class="stat-sub">Total</div>
        </div>
      </div>

      <!-- Panels -->
      <div class="panels-grid">
        <div class="panel">
          <div class="panel-header">
            <h2>Inventory Overview</h2>
            <a href="/admin/inventory" class="btn" style="font-size:0.78rem; padding:0.35rem 0.85rem;">View All</a>
          </div>
          <div class="panel-body">No inventory data yet.</div>
        </div>

        <div class="panel">
          <div class="panel-header">
            <h2>Employees</h2>
            <a href="/admin/employees" class="btn" style="font-size:0.78rem; padding:0.35rem 0.85rem;">View All</a>
          </div>
          <div class="panel-body">No employee data yet.</div>
        </div>
      </div>

    </main>
  </div>

</body>
</html>
