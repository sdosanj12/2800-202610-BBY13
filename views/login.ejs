<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — Food Bank Tracker</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="login.css" />
</head>

<body>

  <!-- Navbar -->
  <header id="navbar-container">
    <%- include('partials/navbar') %>
  </header>


  <!-- Main content -->
  <main class="page-content">
    <div class="card">

      <div class="card-header">
        <h1 class="card-title">Login</h1>
        <hr class="card-divider" />
      </div>

      <!-- Login Form-->
      <form id="loginForm" action="/login" method="POST" novalidate autocomplete="off">

        <!-- Username  -->
        <div class="form-group" id="group-username">
          <label class="form-label" for="username">Username</label>
          <input class="form-input" type="text" id="username" name="username" placeholder="Your username"
            autocomplete="username" aria-describedby="username-error" />
          <span class="form-error" id="username-error" role="alert"></span>
        </div>

        <!--  Password  -->
        <div class="form-group" id="group-password">
          <label class="form-label" for="password">Password</label>
          <div class="input-wrapper">
            <input class="form-input" type="password" id="password" name="password" placeholder="••••••••"
              autocomplete="current-password" aria-describedby="password-error" />
            <button type="button" class="toggle-password" id="togglePassword" aria-label="Toggle password visibility">
              <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </button>
          </div>
          <span class="form-error" id="password-error" role="alert"></span>
        </div>

        <!--  Remember Me + Forgot Password  -->
        <div class="form-extras">
          <label class="checkbox-label">
            <input type="checkbox" name="rememberMe" id="rememberMe" />
            <span class="checkbox-custom"></span>
            Remember me
          </label>
          <a href="/forgot-password" class="link-subtle">Forgot password?</a>
        </div>

        <!--  Submit  -->
        <button type="submit" class="btn-submit" id="submitBtn">
          <span class="btn-text">Login</span>
          <span class="btn-spinner" aria-hidden="true"></span>
        </button>

        <!-- Server-side Error Banner  -->
        <% if (typeof error !=='undefined' && error) { %>
          <div class="server-error" role="alert">
            <%= error %>
          </div>
        <% } %>

      </form>

      <p class="card-footer-text">
        Don't have an account?
        <a href="/signup" class="link-accent">Create one</a>
      </p>

      <p class="card-footer-text" style="margin-top: 0.5rem;">
        Staff member?
        <a href="/admin/login" class="link-accent">Employee Portal</a>
      </p>

    </div>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div id="footer-container">
      <%- include('partials/footer') %>
    </div>
  </footer>


  <!-- Client side validation -->
  <script>
    // show error
    function showError(groupId, errorId, message) {
      document.getElementById(groupId).classList.add("has-error");
      const el = document.getElementById(errorId);
      el.textContent = message;
      el.style.display = "block";
    }

    // clear error
    function clearError(groupId, errorId) {
      document.getElementById(groupId).classList.remove("has-error");
      const el = document.getElementById(errorId);
      el.textContent = "";
      el.style.display = "none";
    }

    //alidate all fields
    function validateForm() {
      let isValid = true;

      const username = document.getElementById("username").value.trim();
      const password = document.getElementById("password").value;

      // Username: min 3, max 20
      if (username === "") {
        showError("group-username", "username-error", "Username is required.");
        isValid = false;
      } else if (username.length < 3) {
        showError("group-username", "username-error", "Username must be at least 3 characters.");
        isValid = false;
      } else if (username.length > 20) {
        showError("group-username", "username-error", "Username must be 20 characters or fewer.");
        isValid = false;
      } else {
        clearError("group-username", "username-error");
      }

      //  Password: required
      if (password === "") {
        showError("group-password", "password-error", "Password is required.");
        isValid = false;
      } else {
        clearError("group-password", "password-error");
      }

      return isValid;
    }

    //  Form submit
    document.getElementById("loginForm").addEventListener("submit", function (e) {
      e.preventDefault();

      if (validateForm()) {
        const btn = document.getElementById("submitBtn");
        btn.disabled = true;
        btn.classList.add("loading");
        btn.querySelector(".btn-text").textContent = "Logging in…";
        this.submit();
      }
    });

    //  clear errors as user types
    document.getElementById("username").addEventListener("input", () =>
      clearError("group-username", "username-error"));

    document.getElementById("password").addEventListener("input", () =>
      clearError("group-password", "password-error"));

    //  Toggle password visibility
    document.getElementById("togglePassword").addEventListener("click", function () {
      const input = document.getElementById("password");
      const icon = document.getElementById("eyeIcon");

      if (input.type === "password") {
        input.type = "text";
        this.setAttribute("aria-label", "Hide password");
        icon.innerHTML = `
            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8
                     a18.45 18.45 0 0 1 5.06-5.94"/>
            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8
                     a18.5 18.5 0 0 1-2.16 3.19"/>
            <line x1="1" y1="1" x2="23" y2="23"/>
          `;
      } else {
        input.type = "password";
        this.setAttribute("aria-label", "Show password");
        icon.innerHTML = `
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          `;
      }
    });
  </script>

</body>

</html>
