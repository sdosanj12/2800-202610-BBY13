<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Generate Codes — Food Bank Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue-dark:  #1a4f7a;
      --blue-mid:   #1e5f94;
      --bg:         #f5f6f8;
      --white:      #ffffff;
      --text-dark:  #2c3e50;
      --text-muted: #6c7a89;
      --border:     #dce3ea;
      --green:      #166534;
      --green-bg:   #dcfce7;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text-dark);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .topbar {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      flex-shrink: 0;
    }

    .topbar-left h1 { font-size: 1.2rem; font-weight: 700; }

    .layout { display: flex; flex: 1; overflow: hidden; }

    .sidebar {
      width: 220px;
      background: var(--white);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      padding: 1.25rem 0;
    }

    .sidebar-section { margin-bottom: 1.5rem; }

    .sidebar-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 0 1.25rem;
      margin-bottom: 0.4rem;
    }

    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.55rem 1.25rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-dark);
      text-decoration: none;
      border-left: 3px solid transparent;
      transition: background 0.15s;
    }

    .sidebar-link:hover { background: var(--bg); }

    .sidebar-link.active {
      background: #edf3f9;
      border-left-color: var(--blue-dark);
      color: var(--blue-dark);
      font-weight: 600;
    }

    .sidebar-bottom {
      margin-top: auto;
      padding: 1rem 1.25rem;
      border-top: 1px solid var(--border);
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .sidebar-bottom strong { display: block; color: var(--text-dark); font-size: 0.85rem; margin-bottom: 2px; }
    .sidebar-bottom a { color: var(--blue-dark); text-decoration: none; font-weight: 600; font-size: 0.8rem; }

    .content { flex: 1; overflow-y: auto; padding: 1.75rem; max-width: 560px; }

    .content h2 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.4rem; }
    .content p { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1.5rem; }

    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.75rem;
    }

    .field { margin-bottom: 1.1rem; }

    .field label {
      display: block;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.35rem;
    }

    .field input, .field select {
      width: 100%;
      padding: 0.6rem 0.875rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      color: var(--text-dark);
      background: var(--bg);
    }

    .field input:focus, .field select:focus {
      outline: none;
      border-color: var(--blue-dark);
      background: var(--white);
    }

    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

    .btn {
      padding: 0.6rem 1.25rem;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      border: 1.5px solid var(--border);
      background: var(--white);
      color: var(--text-dark);
      text-decoration: none;
      transition: background 0.15s;
    }

    .btn-primary {
      background: var(--blue-dark);
      color: var(--white);
      border-color: var(--blue-dark);
      width: 100%;
      margin-top: 0.5rem;
      font-size: 0.95rem;
    }

    .btn-primary:hover { background: var(--blue-mid); }
    .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }

    .result {
      display: none;
      margin-top: 1.25rem;
      background: var(--green-bg);
      border: 1px solid #86efac;
      border-radius: 8px;
      padding: 1.25rem;
    }

    .result h3 {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--green);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 1rem;
    }

    .result-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .result-field label {
      display: block;
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--green);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.2rem;
    }

    .result-field span {
      font-size: 1rem;
      font-weight: 700;
      font-family: monospace;
      color: var(--text-dark);
    }

    .result-field.full { grid-column: 1 / -1; }

    .warning {
      font-size: 0.78rem;
      color: #854d0e;
      background: #fef9c3;
      border: 1px solid #fde68a;
      border-radius: 6px;
      padding: 0.6rem 0.875rem;
      margin-bottom: 0.75rem;
    }

    .btn-copy {
      width: 100%;
      background: var(--white);
      border-color: #86efac;
      color: var(--green);
      font-weight: 600;
    }

    .error-msg {
      display: none;
      color: #b91c1c;
      background: #fee2e2;
      border: 1px solid #fca5a5;
      border-radius: 6px;
      padding: 0.6rem 0.875rem;
      font-size: 0.85rem;
      margin-top: 0.75rem;
    }
  </style>
</head>
<body>

  <div class="topbar">
    <div class="topbar-left">
      <h1>Add Employee — <%= employee.name %></h1>
    </div>
  </div>

  <div class="layout">

    <aside class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-label">Overview</div>
        <a href="/admin/dashboard" class="sidebar-link">📊 Dashboard</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Inventory</div>
        <a href="#" class="sidebar-link">📦 All Items</a>
        <a href="#" class="sidebar-link">📋 History &amp; Audit Log</a>
        <a href="#" class="sidebar-link">⚠️ Low Stock Alerts</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Employees</div>
        <a href="/admin/employees" class="sidebar-link">👥 All Employees</a>
        <a href="/admin/employees/codes" class="sidebar-link active">🔑 Generate Codes</a>
      </div>
      <div class="sidebar-bottom">
        <strong><%= employee.name %></strong>
        <%= employee.employeeId %><br />
        <a href="/admin/logout">Log out</a>
      </div>
    </aside>

    <main class="content">
      <h2>Add New Employee</h2>
      <p>Fill in the details below to create a new employee account. Share the generated ID and PIN with them securely.</p>

      <div class="card">

        <div class="field-row">
          <div class="field">
            <label>Full Name</label>
            <input type="text" id="emp-name" placeholder="Jane Doe" />
          </div>
          <div class="field">
            <label>Email</label>
            <input type="email" id="emp-email" placeholder="jane@example.com" />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label>Role</label>
            <select id="emp-role">
              <option value="admin">Admin</option>
              <option value="manager">Manager</option>
              <option value="staff">Staff</option>
            </select>
          </div>
          <div class="field">
            <label>Department</label>
            <input type="text" id="emp-department" placeholder="e.g. General" />
          </div>
        </div>

        <div class="field">
          <label>PIN (4–8 digits)</label>
          <input type="password" id="emp-pin" placeholder="e.g. 1234" maxlength="8" />
        </div>

        <button class="btn btn-primary" id="generateBtn" onclick="generateEmployee()">
          Create Employee
        </button>

        <div class="error-msg" id="errorMsg"></div>

        <div class="result" id="result">
          <h3>✅ Employee Created Successfully</h3>
          <div class="result-grid">
            <div class="result-field full">
              <label>Employee ID</label>
              <span id="res-empid"></span>
            </div>
            <div class="result-field">
              <label>Name</label>
              <span id="res-name"></span>
            </div>
            <div class="result-field">
              <label>Role</label>
              <span id="res-role"></span>
            </div>
            <div class="result-field">
              <label>Department</label>
              <span id="res-department"></span>
            </div>
            <div class="result-field">
              <label>Email</label>
              <span id="res-email"></span>
            </div>
          </div>
          <div class="warning">⚠️ This PIN is only shown once. Share it securely with the employee.</div>
          <div class="result-field" style="margin-bottom:1rem;">
            <label>Temporary PIN</label>
            <span id="res-pin"></span>
          </div>
          <button class="btn btn-copy" onclick="copyResult()">Copy ID &amp; PIN to Clipboard</button>
        </div>

      </div>
    </main>
  </div>

  <script>
    async function generateEmployee() {
      const name       = document.getElementById('emp-name').value.trim();
      const email      = document.getElementById('emp-email').value.trim();
      const role       = document.getElementById('emp-role').value;
      const department = document.getElementById('emp-department').value.trim() || 'General';
      const pin        = document.getElementById('emp-pin').value.trim();

      const errorMsg = document.getElementById('errorMsg');
      errorMsg.style.display = 'none';
      document.getElementById('result').style.display = 'none';

      if (!name || !email || !pin) {
        errorMsg.textContent = 'Please fill in all required fields.';
        errorMsg.style.display = 'block';
        return;
      }

      if (!/^\d{4,8}$/.test(pin)) {
        errorMsg.textContent = 'PIN must be 4–8 digits only.';
        errorMsg.style.display = 'block';
        return;
      }

      const btn = document.getElementById('generateBtn');
      btn.disabled = true;
      btn.textContent = 'Creating...';

      try {
        const res = await fetch('/admin/employees/generate-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, role, department, pin })
        });

        const data = await res.json();

        if (!res.ok) {
          errorMsg.textContent = data.error || 'Failed to create employee.';
          errorMsg.style.display = 'block';
          return;
        }

        document.getElementById('res-empid').textContent      = data.employeeId;
        document.getElementById('res-name').textContent       = data.name;
        document.getElementById('res-email').textContent      = data.email;
        document.getElementById('res-role').textContent       = data.role;
        document.getElementById('res-department').textContent = data.department;
        document.getElementById('res-pin').textContent        = data.pin;
        document.getElementById('result').style.display       = 'block';

        // Reset form
        document.getElementById('emp-name').value       = '';
        document.getElementById('emp-email').value      = '';
        document.getElementById('emp-pin').value        = '';
        document.getElementById('emp-department').value = '';

      } catch (err) {
        errorMsg.textContent = 'Network error. Please try again.';
        errorMsg.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Create Employee';
      }
    }

    function copyResult() {
      const id  = document.getElementById('res-empid').textContent;
      const pin = document.getElementById('res-pin').textContent;
      navigator.clipboard.writeText('Employee ID: ' + id + '\nPIN: ' + pin);
      alert('Copied to clipboard!');
    }
  </script>

</body>
</html>