<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Generate Codes — Food Bank Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue-dark:  #1a4f7a;
      --blue-mid:   #1e5f94;
      --bg:         #f5f6f8;
      --white:      #ffffff;
      --text-dark:  #2c3e50;
      --text-muted: #6c7a89;
      --border:     #dce3ea;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text-dark);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .topbar {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      flex-shrink: 0;
    }

    .topbar-left h1 { font-size: 1.2rem; font-weight: 700; }

    .btn {
      padding: 0.5rem 1.1rem;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      border: 1.5px solid var(--border);
      background: var(--white);
      color: var(--text-dark);
      text-decoration: none;
      transition: background 0.15s;
    }

    .btn:hover { background: var(--bg); }

    .btn-primary {
      background: var(--blue-dark);
      color: var(--white);
      border-color: var(--blue-dark);
    }

    .btn-primary:hover { background: var(--blue-mid); border-color: var(--blue-mid); }

    .layout { display: flex; flex: 1; overflow: hidden; }

    .sidebar {
      width: 220px;
      background: var(--white);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      padding: 1.25rem 0;
    }

    .sidebar-section { margin-bottom: 1.5rem; }

    .sidebar-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 0 1.25rem;
      margin-bottom: 0.4rem;
    }

    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.55rem 1.25rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-dark);
      text-decoration: none;
      border-left: 3px solid transparent;
      transition: background 0.15s;
    }

    .sidebar-link:hover { background: var(--bg); }

    .sidebar-link.active {
      background: #edf3f9;
      border-left-color: var(--blue-dark);
      color: var(--blue-dark);
      font-weight: 600;
    }

    .sidebar-bottom {
      margin-top: auto;
      padding: 1rem 1.25rem;
      border-top: 1px solid var(--border);
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .sidebar-bottom strong { display: block; color: var(--text-dark); font-size: 0.85rem; margin-bottom: 2px; }
    .sidebar-bottom a { color: var(--blue-dark); text-decoration: none; font-weight: 600; font-size: 0.8rem; }

    .content { flex: 1; overflow-y: auto; padding: 1.75rem; }

    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 2rem;
      max-width: 520px;
    }

    .card h2 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.4rem; }
    .card p { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1.5rem; }

    .code-result {
      display: none;
      margin-top: 1.5rem;
      padding: 1.25rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
    }

    .code-result.show { display: block; }

    .code-label {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }

    .code-value {
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--blue-dark);
      font-family: monospace;
      margin-bottom: 1rem;
    }

    .pin-value {
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--text-dark);
      font-family: monospace;
      margin-bottom: 1rem;
    }

    .copy-btn {
      font-size: 0.78rem;
      padding: 0.35rem 0.75rem;
    }

    .alert-info {
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      color: #1d4ed8;
      border-radius: 6px;
      padding: 0.65rem 0.9rem;
      font-size: 0.82rem;
      margin-top: 1rem;
    }
  </style>
</head>
<body>

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-left">
      <h1>Generate Codes — <%= employee.name %></h1>
    </div>
  </div>

  <div class="layout">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-label">Overview</div>
        <a href="/admin/dashboard" class="sidebar-link">📊 Dashboard</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Inventory</div>
        <a href="/admin/inventory" class="sidebar-link">📦 All Items</a>
        <a href="/admin/inventory/history" class="sidebar-link">📋 History &amp; Audit Log</a>
        <a href="/admin/inventory/alerts" class="sidebar-link">⚠️ Low Stock Alerts</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Employees</div>
        <a href="/admin/employees" class="sidebar-link">👥 All Employees</a>
        <a href="/admin/employees/codes" class="sidebar-link active">🔑 Generate Codes</a>
      </div>
      <div class="sidebar-bottom">
        <strong><%= employee.name %></strong>
        <%= employee.employeeId %><br />
        <a href="/admin/logout">Log out</a>
      </div>
    </aside>

    <!-- CONTENT -->
    <main class="content">
      <div class="card">
        <h2>Generate Employee ID &amp; PIN</h2>
        <p>Creates a unique Employee ID and temporary PIN. Give these to the new employee so they can log in.</p>

        <button class="btn btn-primary" onclick="generateCode()">Generate Code</button>

        <div class="code-result" id="codeResult">
          <div class="code-label">Employee ID</div>
          <div class="code-value" id="generatedId">—</div>

          <div class="code-label">Temporary PIN</div>
          <div class="pin-value" id="generatedPin">—</div>

          <button class="btn copy-btn" onclick="copyAll()">Copy Both</button>

          <div class="alert-info" style="margin-top:1rem;">
            ⚠️ This PIN is only shown once. Make sure to pass it to the employee securely.
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    function generateCode() {
      fetch('/admin/employees/generate-code', { method: 'POST' })
        .then(res => res.json())
        .then(data => {
          if (data.employeeId && data.pin) {
            document.getElementById('generatedId').textContent = data.employeeId;
            document.getElementById('generatedPin').textContent = data.pin;
            document.getElementById('codeResult').classList.add('show');
          } else {
            alert('Failed to generate code.');
          }
        });
    }

    function copyAll() {
      const id = document.getElementById('generatedId').textContent;
      const pin = document.getElementById('generatedPin').textContent;
      navigator.clipboard.writeText('Employee ID: ' + id + '\nPIN: ' + pin);
      alert('Copied to clipboard!');
    }
  </script>

</body>
</html>