<!--
  Navigation Bar (Role‑Based)
  ---------------------------
  Renders links based on logged‑in user role:
    • Client → dashboard, request page
    • Volunteer → dashboard, inventory, clock‑in
    • Admin → dashboard, requests
  Also displays logout link when a user is authenticated.
  @author YenYi Huang
-->

<nav class="navbar">
  <a href="/" class="nav-brand">Food Bank Tracker</a>

  <ul class="nav-links">
    <% if (locals.user && user.roles && user.roles.includes('client')) { %>
      <li><a href="/client/dashboard"
          class="<%= locals.currentPath === '/client/dashboard' ? 'nav-active' : '' %>">Dashboard</a></li>
      <li><a href="/request">Request</a></li>

      <% } else if (locals.user && user.roles && user.roles.includes('volunteer')) { %>
        <li><a href="/volunteer/dashboard"
            class="<%= locals.currentPath === '/volunteer/dashboard' ? 'nav-active' : '' %>">Dashboard</a></li>
        <li><a href="/inventory">Inventory</a></li>
        <li><a href="/clockin">Clock In</a></li>

        <% } else if (locals.user && user.roles && user.roles.includes('admin')) { %>
          <li><a href="/admin/dashboard"
              class="<%= locals.currentPath === '/admin/dashboard' ? 'nav-active' : '' %>">Dashboard</a></li>
          <li><a href="/requests">Requests</a></li>

          <% } %>

            <% if (locals.user) { %>
              <li><a href="/logout" class="nav-logout">Logout</a></li>
              <% } %>
  </ul>
</nav>