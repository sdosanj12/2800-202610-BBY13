<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Low Stock Alerts — Food Bank Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/low-stock-alerts-admin.css" />
</head>
<body>

  <!-- TOPBAR -->
  <nav class="topbar">
    <a href="/admin/dashboard" class="topbar-brand">🥫 Food Bank Tracker</a>
    <div class="topbar-right">
      <span class="topbar-user">Admin: <strong><%= username %></strong></span>
      <a href="/admin/logout" class="btn-shell">Log out</a>
    </div>
  </nav>

  <div class="shell">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-label">Overview</div>
        <a href="/admin/dashboard" class="sidebar-link"><span class="icon">📊</span> Dashboard</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Inventory</div>
        <a href="/admin/inventory" class="sidebar-link"><span class="icon">📦</span> All Items</a>
        <a href="/admin/audit-log" class="sidebar-link"><span class="icon">📋</span> History &amp; Audit Log</a>
        <a href="/admin/low-stock-alerts" class="sidebar-link active"><span class="icon">⚠️</span> Low Stock Alerts</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Employees</div>
        <a href="/admin/employees" class="sidebar-link"><span class="icon">👥</span> All Employees</a>
        <a href="/admin/employees/codes" class="sidebar-link"><span class="icon">🔑</span> Generate Codes</a>
      </div>
      <div class="sidebar-bottom">
        <strong><%= username %></strong>
        <a href="/admin/logout">Log out</a>
      </div>
    </aside>

    <!-- CONTENT -->
    <main class="content">
      <div class="page-header">
        <div>
          <h1>Low Stock Alerts</h1>
          <div class="sub"><%= new Date().toLocaleDateString('en-CA', {weekday:'long',year:'numeric',month:'long',day:'numeric'}) %></div>
        </div>
        <div class="header-actions">
          <form method="POST" action="/admin/low-stock-alerts/mark-all-read" style="display:inline;">
            <button class="btn-action">Mark All Read</button>
          </form>
          <form method="POST" action="/admin/low-stock-alerts/dismiss-read" style="display:inline;">
            <button class="btn-action btn-action-primary">Dismiss All Read</button>
          </form>
        </div>
      </div>

      <!-- Stat Cards -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Total Alerts</div>
          <div class="stat-value"><%= stats.total %></div>
          <div class="stat-sub">Active notifications</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Unread</div>
          <div class="stat-value"><%= stats.unread %></div>
          <div class="stat-sub">Require attention</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Critical</div>
          <div class="stat-value"><%= stats.critical %></div>
          <div class="stat-sub">Out of stock items</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Low Stock</div>
          <div class="stat-value"><%= stats.lowStock %></div>
          <div class="stat-sub">Items below threshold</div>
        </div>
      </div>

      <!-- Filter Tabs -->
      <div class="filter-tabs">
        <a href="/admin/low-stock-alerts?filter=all"       class="tab-btn <%= (filter==='all'||!filter) ? 'active' : '' %>">All Alerts</a>
        <a href="/admin/low-stock-alerts?filter=unread"    class="tab-btn <%= filter==='unread'    ? 'active' : '' %>">Unread</a>
        <a href="/admin/low-stock-alerts?filter=critical"  class="tab-btn <%= filter==='critical'  ? 'active' : '' %>">Critical</a>
        <a href="/admin/low-stock-alerts?filter=low-stock" class="tab-btn <%= filter==='low-stock' ? 'active' : '' %>">Low Stock</a>
        <a href="/admin/low-stock-alerts?filter=read"      class="tab-btn <%= filter==='read'      ? 'active' : '' %>">Read</a>
      </div>

      <!-- Alerts -->
      <% if (alerts.length === 0) { %>
        <div class="empty-state">
          <svg width="56" height="56" fill="none" viewBox="0 0 24 24" stroke="#9ca3af">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <h6>No alerts in this category.</h6>
          <p>All items are well-stocked!</p>
        </div>
      <% } else { %>
        <div class="alerts-list">
          <% alerts.forEach(alert => {
            const item = alert.relatedId;
            const isOut = item ? item.status === 'out-of-stock' : (alert.type === 'low-stock' && alert.message.includes('out of stock'));
            const barColor = isOut ? '#ef4444' : '#f59e0b';
            const cardClass = alert.read ? 'notif-card' : (isOut ? 'notif-card critical-card' : 'notif-card unread');
          %>
            <div class="<%= cardClass %>">
              <div class="severity-icon <%= isOut ? 'severity-icon-critical' : 'severity-icon-low' %>">
                <% if (isOut) { %>
                  <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#ef4444"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                <% } else { %>
                  <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#f59e0b"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <% } %>
              </div>
              <div class="notif-body">
                <div class="notif-top">
                  <div class="notif-title">
                    <strong><%= item ? item.name : 'Unknown Item' %></strong>
                    <% if (alert.read) { %>
                      <span class="badge badge-read">Read</span>
                    <% } else if (isOut) { %>
                      <span class="badge badge-critical">Out of Stock</span>
                    <% } else { %>
                      <span class="badge badge-low">Low Stock</span>
                    <% } %>
                    <% if (item) { %>
                      <span style="font-size:0.78rem;color:var(--color-muted);"><%= item.category %> · <%= item.storageLocation || '—' %></span>
                    <% } %>
                  </div>
                  <span class="notif-date"><%= new Date(alert.createdAt).toLocaleString('en-CA',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
                </div>
                <p class="notif-msg"><%= alert.message %></p>
                <% if (item) { %>
                  <div class="stock-bar-wrap">
                    <span class="stock-bar-qty"><%= item.quantity %> <%= item.unit %></span>
                    <div class="stock-bar-track">
                      <div class="stock-bar-fill" style="width:<%= item.quantity === 0 ? 2 : 10 %>%;background:<%= barColor %>;"></div>
                    </div>
                    <span class="stock-bar-pct"><%= item.quantity === 0 ? '0%' : 'Low' %></span>
                  </div>
                <% } %>
                <div class="notif-actions">
                  <% if (item) { %>
                    <button class="btn-notif btn-notif-primary" onclick="openRestock('<%= alert._id %>','<%= item.name %>','<%= item.unit %>')">Restock</button>
                  <% } %>
                  <% if (!alert.read) { %>
                    <form method="POST" action="/admin/low-stock-alerts/<%= alert._id %>/read" style="display:inline;">
                      <button class="btn-notif btn-notif-outline">Mark as Read</button>
                    </form>
                  <% } %>
                  <form method="POST" action="/admin/low-stock-alerts/<%= alert._id %>/dismiss" style="display:inline;">
                    <button class="btn-notif btn-notif-danger">Dismiss</button>
                  </form>
                  <% if (item) { %>
                    <a href="/admin/inventory" class="btn-notif btn-notif-outline">View Item</a>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </main>
  </div>

  <!-- RESTOCK MODAL -->
  <div class="modal-overlay" id="restockModal">
    <div class="modal">
      <button class="modal-close" onclick="document.getElementById('restockModal').classList.remove('open')">✕</button>
      <h2>Restock Item</h2>
      <p>Update quantity for <strong id="restockItemName"></strong>.</p>
      <form id="restockForm" method="POST" action="">
        <div class="modal-row">
          <div class="modal-field">
            <label>New Quantity</label>
            <input type="number" name="quantity" id="restockQty" min="1" placeholder="Enter quantity" required />
          </div>
          <div class="modal-field">
            <label>Unit</label>
            <input type="text" id="restockUnit" readonly />
          </div>
        </div>
        <div class="modal-field">
          <label>Notes (optional)</label>
          <textarea name="notes" rows="2" placeholder="e.g. Received from donor…"></textarea>
        </div>
        <div class="modal-footer-row">
          <button type="button" class="btn-notif btn-notif-outline" onclick="document.getElementById('restockModal').classList.remove('open')">Cancel</button>
          <button type="submit" class="btn-notif btn-notif-primary" style="padding:0.45rem 1.25rem;">Confirm Restock</button>
        </div>
      </form>
    </div>
  </div>

  <footer class="site-footer">
    <span>© 2026 Food Bank Tracker</span>
    <div class="footer-links">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
      <a href="#">Contact Support</a>
    </div>
  </footer>

  <script>
    function openRestock(alertId, itemName, unit) {
      document.getElementById('restockForm').action = '/admin/low-stock-alerts/' + alertId + '/restock';
      document.getElementById('restockItemName').textContent = itemName;
      document.getElementById('restockUnit').value = unit;
      document.getElementById('restockQty').value = '';
      document.getElementById('restockModal').classList.add('open');
    }
    document.getElementById('restockModal').addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('open');
    });
  </script>
</body>
</html>