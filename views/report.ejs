<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Food Bank Tracker - Reports</title>

    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/report.css">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link
        href="https://fonts.googleapis.com/css2?family=Alan+Sans:wght@300..900&family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Lexend+Deca:wght@100..900&display=swap"
        rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-light">

    <header id="navbar-container">
        <%- include('partials/navbar') %>
    </header>

    <main class="container py-4">
        <section class="report-section">
            <h1 class="mb-4">Food Bank Reports</h1>

            <!-- Line Chart Section -->
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h2 class="card-title h4 mb-3">Monthly Food Distribution</h2>
                    <div class="chart-container" style="position: relative; height: 300px;">
                        <canvas id="lineChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Bar Charts Row -->
            <div class="row">
                <div class="col-12 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h2 class="card-title h4 mb-3">Most Requested Items</h2>
                            <div class="chart-container" style="position: relative; height: 300px;">
                                <canvas id="requestedItemsChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h2 class="card-title h4 mb-3">Total Monthly Visits</h2>
                            <div class="chart-container" style="position: relative; height: 300px;">
                                <canvas id="monthlyVisitsChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Data Table Section -->
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="card-title h4 mb-3">Monthly Distribution Data</h2>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle" id="dataTable">
                            <thead class="table-dark">
                                <tr>
                                    <th scope="col">Month</th>
                                    <th scope="col">Families Served</th>
                                    <th scope="col">Total Items Distributed</th>
                                    <th scope="col">Visits</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof monthlyData !=='undefined' && monthlyData.length> 0) { %>
                                    <% monthlyData.forEach(row=> { %>
                                        <tr>
                                            <th>
                                                <%= row.month || "Unknown" %>
                                            </th>
                                            <td>
                                                <%= (typeof row.familiesServed !=='undefined' ? row.familiesServed :
                                                    row.families_served || 0).toLocaleString() %>
                                            </td>
                                            <td>
                                                <%= (typeof row.itemsDistributed !=='undefined' ? row.itemsDistributed :
                                                    row.items_distributed || 0).toLocaleString() %>
                                            </td>
                                            <td>
                                                <%= (typeof row.visits !=='undefined' ? row.visits : row.total_visits ||
                                                    0).toLocaleString() %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="4" class="text-center text-muted py-4">No report
                                                        data
                                                        historical trends found.</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </section>
    </main>

    <footer class="footer mt-auto">
        <%- include('partials/footer') %>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <div id="ejs-backend-bridge"
        data-chart='<%- (typeof monthlyData !== "undefined" && monthlyData) ? JSON.stringify(monthlyData) : "[]" %>'
        data-items='<%- (typeof topItems !== "undefined" && topItems) ? JSON.stringify(topItems) : "[]" %>'
        style="display: none;">
    </div>

    <script>
        const bridgeEl = document.getElementById('ejs-backend-bridge');
        window.rawChartData = JSON.parse(bridgeEl.dataset.chart);
        window.rawItemData = JSON.parse(bridgeEl.dataset.items);

        console.log("Data successfully extracted via DOM bridge:", window.rawChartData);
    </script>
    <script src="/report.js"></script>
</body>

</html>