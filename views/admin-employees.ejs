<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>All Employees — Food Bank Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/admin-employees.css" />
</head>
<body>

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-left">
      <h1>All Employees — <%= employee.name %></h1>
    </div>
    <div class="topbar-right">
      <button class="btn" onclick="document.getElementById('generateModal').classList.add('open')">Generate Code</button>
      <a href="/admin/employees/codes" class="btn btn-primary">+ Add Employee</a>
    </div>
  </div>

  <div class="layout">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-label">Overview</div>
        <a href="/admin/dashboard" class="sidebar-link">📊 Dashboard</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Requests</div>
        <a href="/admin/requests" class="sidebar-link">📝 Food Requests</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Inventory</div>
        <a href="/admin/inventory" class="sidebar-link">📦 All Items</a>
        <a href="/admin/audit-log" class="sidebar-link">📋 History &amp; Audit Log</a>
        <a href="/admin/low-stock-alerts" class="sidebar-link">⚠️ Low Stock Alerts</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-label">Employees</div>
        <a href="/admin/employees" class="sidebar-link active">👥 All Employees</a>
        <a href="/admin/employees/codes" class="sidebar-link">🔑 Generate Codes</a>
      </div>
      <div class="sidebar-bottom">
        <strong><%= employee.name %></strong>
        <%= employee.employeeId %><br />
        <a href="/admin/logout">Log out</a>
      </div>
    </aside>

    <!-- CONTENT -->
    <main class="content">

      <!-- Filter tabs -->
      <div class="filter-tabs">
        <button class="tab-btn active" onclick="filterTable('all', this)">All</button>
        <button class="tab-btn" onclick="filterTable('active', this)">Active</button>
        <button class="tab-btn" onclick="filterTable('pending', this)">Pending</button>
        <button class="tab-btn" onclick="filterTable('inactive', this)">Inactive</button>
      </div>

      <!-- Table -->
      <div class="table-wrap">
        <% if (employees && employees.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Employee</th>
                <th>Status</th>
                <th>Role</th>
                <th>Last Active</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="employeeTableBody">
              <% employees.forEach(function(emp) { %>
                <tr data-status="<%= emp.isActive ? 'active' : 'inactive' %>">
                  <td>
                    <div class="employee-name"><%= emp.name %></div>
                    <div class="employee-email"><%= emp.email %></div>
                  </td>
                  <td>
                    <span class="badge <%= emp.isActive ? 'badge-active' : 'badge-inactive' %>">
                      <%= emp.isActive ? 'Active' : 'Inactive' %>
                    </span>
                  </td>
                  <td><span class="role-badge"><%= emp.role %></span></td>
                  <td><%= emp.lastLogin ? new Date(emp.lastLogin).toLocaleDateString() : 'Never' %></td>
                  <td>
                    <button class="btn" style="font-size:0.78rem; padding:0.3rem 0.75rem;"
                        onclick="openViewModal(
                            '<%= emp.name %>',
                            '<%= emp.email %>',
                            '<%= emp.employeeId %>',
                            '<%= emp.lastLogin ? new Date(emp.lastLogin).toLocaleDateString() : "Never" %>',
                            '<%= emp._id %>'
                        )">View</button>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <div class="empty-state">No employees found.</div>
        <% } %>
      </div>

    </main>
  </div>

<!-- VIEW EMPLOYEE MODAL -->
<div class="modal-overlay" id="viewModal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('viewModal')">✕</button>

    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.25rem;">
      <div class="modal-avatar">👤</div>
      <div class="modal-name" id="modal-name"></div>
    </div>

    <div class="modal-field">
      <label>Email</label>
      <input type="text" id="modal-email" readonly />
    </div>

    <div class="modal-field">
      <label>Employee Code</label>
      <div class="modal-field-row">
        <input type="text" id="modal-empid" readonly />
        <button class="btn btn-danger" style="font-size:0.78rem; padding:0.4rem 0.75rem; white-space:nowrap;"
          onclick="deleteEmployee()">Delete</button>
      </div>
    </div>

    <div class="modal-field">
      <label>Last Active</label>
      <input type="text" id="modal-lastactive" readonly />
    </div>

    <div class="modal-field">
      <label>Role</label>
      <input type="text" id="modal-role" readonly />
    </div>

    <div class="modal-field">
      <label>Status</label>
      <input type="text" id="modal-status" readonly />
    </div>
  </div>
</div>

<!-- GENERATE CODE MODAL -->
<div class="modal-overlay" id="generateModal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('generateModal')">✕</button>
    <h2 style="margin-bottom:1.25rem; font-size:1.1rem;">Generate Employee Code</h2>
    <p style="font-size:0.875rem; color:var(--text-muted); margin-bottom:1.5rem;">
      Generate a one-time Employee ID and PIN for a new staff member to use at first login.
    </p>
    <button class="btn btn-primary" onclick="generateCode()" style="width:100%; margin-bottom:1rem;">
      Generate Code
    </button>
    <div id="generateResult" style="display:none; background:var(--bg); border:1px solid var(--border); border-radius:8px; padding:1rem;">
      <div style="margin-bottom:0.75rem;">
        <div style="font-size:0.75rem; font-weight:600; color:var(--text-muted); margin-bottom:0.25rem;">EMPLOYEE ID</div>
        <div id="gen-empid" style="font-size:1.1rem; font-weight:700; font-family:monospace;"></div>
      </div>
      <div style="margin-bottom:1rem;">
        <div style="font-size:0.75rem; font-weight:600; color:var(--text-muted); margin-bottom:0.25rem;">PIN</div>
        <div id="gen-pin" style="font-size:1.1rem; font-weight:700; font-family:monospace;"></div>
      </div>
      <button class="btn" onclick="copyGenerated()" style="width:100%;">Copy to Clipboard</button>
    </div>
  </div>
</div>

<script>
  let currentEmployeeId = null;

  // ── View modal ──
  function openViewModal(name, email, empId, lastActive, dbId, role, status) {
    currentEmployeeId = dbId;
    document.getElementById('modal-name').textContent = name;
    document.getElementById('modal-email').value = email;
    document.getElementById('modal-empid').value = empId;
    document.getElementById('modal-lastactive').value = lastActive;
    document.getElementById('modal-role').value = role;
    document.getElementById('modal-status').value = status;
    document.getElementById('viewModal').classList.add('open');
  }

  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
    // Reset generate result when closing generate modal
    if (id === 'generateModal') {
      document.getElementById('generateResult').style.display = 'none';
    }
  }

  // Close modal when clicking outside
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) {
        this.classList.remove('open');
        if (this.id === 'generateModal') {
          document.getElementById('generateResult').style.display = 'none';
        }
      }
    });
  });

  // ── Filter tabs ──
  function filterTable(status, btn) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('#employeeTableBody tr').forEach(row => {
      row.style.display = (status === 'all' || row.dataset.status === status) ? '' : 'none';
    });
  }

  // ── Delete employee ──
  function deleteEmployee() {
    if (!currentEmployeeId) return;
    if (!confirm('Are you sure you want to delete this employee? This cannot be undone.')) return;
    fetch('/admin/employees/' + currentEmployeeId, { method: 'DELETE' })
      .then(res => res.json())
      .then(data => {
        if (data.success) window.location.reload();
        else alert('Failed to delete employee.');
      });
  }

  // ── Generate code ──
  function generateCode() {
    fetch('/admin/employees/generate-code', { method: 'POST' })
      .then(res => res.json())
      .then(data => {
        if (data.employeeId && data.pin) {
          document.getElementById('gen-empid').textContent = data.employeeId;
          document.getElementById('gen-pin').textContent = data.pin;
          document.getElementById('generateResult').style.display = 'block';
        } else {
          alert('Failed to generate code.');
        }
      });
  }

  function copyGenerated() {
    const id = document.getElementById('gen-empid').textContent;
    const pin = document.getElementById('gen-pin').textContent;
    navigator.clipboard.writeText('Employee ID: ' + id + '\nPIN: ' + pin);
    alert('Copied to clipboard!');
  }
</script>

</body>
</html>